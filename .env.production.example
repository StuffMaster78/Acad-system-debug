# Core
DJANGO_ENV=production
SECRET_KEY=replace-with-a-long-random-value
DEBUG=False
PRIMARY_DOMAIN=writerscreek.com
ALLOWED_HOSTS=writerscreek.com,www.writerscreek.com,app.writerscreek.com,admin.writerscreek.com,gradecrest.com,www.gradecrest.com,app.gradecrest.com,nursemygrade.com,www.nursemygrade.com,app.nursemygrade.com,essaymaniacs.com,www.essaymaniacs.com,app.essaymaniacs.com,researchpapermate.com,www.researchpapermate.com,app.researchpapermate.com
CORS_ALLOWED_ORIGINS=https://writerscreek.com,https://app.writerscreek.com,https://admin.writerscreek.com,https://gradecrest.com,https://app.gradecrest.com,https://nursemygrade.com,https://app.nursemygrade.com,https://essaymaniacs.com,https://app.essaymaniacs.com,https://researchpapermate.com,https://app.researchpapermate.com
CSRF_TRUSTED_ORIGINS=https://writerscreek.com,https://app.writerscreek.com,https://admin.writerscreek.com,https://gradecrest.com,https://app.gradecrest.com,https://nursemygrade.com,https://app.nursemygrade.com,https://essaymaniacs.com,https://app.essaymaniacs.com,https://researchpapermate.com,https://app.researchpapermate.com
SESSION_COOKIE_DOMAIN=.writerscreek.com
CSRF_COOKIE_DOMAIN=.writerscreek.com
WAGTAILADMIN_BASE_URL=https://admin.writerscreek.com

# PostgreSQL and Redis
POSTGRES_DB_NAME=writing_system_db
POSTGRES_USER_NAME=writing_system
POSTGRES_PASSWORD=replace-with-a-strong-password
REDIS_PASSWORD=replace-with-a-strong-password

# Encryption
FIELD_ENCRYPTION_KEY=replace-with-a-fernet-key
TOKEN_ENCRYPTION_KEY=replace-with-a-fernet-key

# DigitalOcean Spaces — application media credentials
STORAGE_BACKEND=do_spaces
USE_S3=True
DO_SPACES_REGION=nyc3
AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
AWS_S3_REGION_NAME=nyc3
AWS_ACCESS_KEY_ID=replace-with-app-spaces-key
AWS_SECRET_ACCESS_KEY=replace-with-app-spaces-secret
AWS_STORAGE_BUCKET_NAME=replace-with-media-space-name
DO_SPACES_CDN_ENDPOINT=

# DigitalOcean Spaces — restricted backup credentials
BACKUP_AWS_ACCESS_KEY_ID=replace-with-backup-only-key
BACKUP_AWS_SECRET_ACCESS_KEY=replace-with-backup-only-secret
BACKUP_AWS_STORAGE_BUCKET_NAME=replace-with-backup-space-name
BACKUP_AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
BACKUP_AWS_S3_REGION_NAME=nyc3
BACKUP_ENCRYPTION_KEY=replace-with-a-separate-long-random-passphrase

# Resend transactional email
DEFAULT_EMAIL_PROVIDER=resend
RESEND_API_KEY=re_replace_me
RESEND_WEBHOOK_SECRET=whsec_replace_me
DEFAULT_FROM_EMAIL="WritersCreek <notifications@notify.writerscreek.com>"

# Cloudflare Turnstile. Keep disabled until the widgets are configured.
TURNSTILE_ENABLED=False
TURNSTILE_SECRET_KEY=

# Monitoring
SENTRY_DSN=

# Brand runtime URLs
NUXT_PUBLIC_WC_API_BASE=https://writerscreek.com
NUXT_PUBLIC_WC_APP_URL=https://app.writerscreek.com
NUXT_PUBLIC_WC_STAFF_URL=https://admin.writerscreek.com
NUXT_PUBLIC_GC_API_BASE=https://gradecrest.com
NUXT_PUBLIC_GC_APP_URL=https://app.gradecrest.com
NUXT_PUBLIC_NMG_API_BASE=https://nursemygrade.com
NUXT_PUBLIC_NMG_APP_URL=https://app.nursemygrade.com
NUXT_PUBLIC_EM_API_BASE=https://essaymaniacs.com
NUXT_PUBLIC_EM_APP_URL=https://app.essaymaniacs.com
NUXT_PUBLIC_RPM_API_BASE=https://researchpapermate.com
NUXT_PUBLIC_RPM_APP_URL=https://app.researchpapermate.com

# CI appends immutable GHCR image names during deployment.
