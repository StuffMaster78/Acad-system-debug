# =============================================================================
# Writers Creek — Production environment
# Copy this file to .env on the production server and fill in every value
# marked  ← CHANGE THIS  before starting the stack.
#
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Generate FIELD_ENCRYPTION_KEY / TOKEN_ENCRYPTION_KEY:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================

# ── Django core ───────────────────────────────────────────────────────────────
DJANGO_ENV=production
DEBUG=False
SECRET_KEY=                                          # ← CHANGE THIS (64-char random string)

ALLOWED_HOSTS=writerscreek.com,www.writerscreek.com,admin.writerscreek.com

WAGTAILADMIN_BASE_URL=https://admin.writerscreek.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
POSTGRES_HOST=db
DB_PORT=5432
POSTGRES_USER_NAME=writing_system_user
POSTGRES_PASSWORD=                                   # ← CHANGE THIS
POSTGRES_DB_NAME=writing_system_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                                      # ← CHANGE THIS
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0
COMMUNICATIONS_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/2
CHANNEL_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/3

# ── Email ─────────────────────────────────────────────────────────────────────
# Option A — SendGrid (recommended for production deliverability)
EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
DEFAULT_EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=                                    # ← CHANGE THIS

# Option B — Gmail SMTP (uncomment and comment out Option A if preferred)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_EMAIL_PROVIDER=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com              # ← CHANGE THIS
# EMAIL_HOST_PASSWORD=your-16-char-app-password     # ← CHANGE THIS

DEFAULT_FROM_EMAIL=noreply@writerscreek.com

# ── Frontend URLs (used in email links) ───────────────────────────────────────
FRONTEND_URL=https://writerscreek.com
WRITER_FRONTEND_URL=https://writerscreek.com
CLIENT_FRONTEND_URL=https://writerscreek.com
STAFF_FRONTEND_URL=https://admin.writerscreek.com

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://writerscreek.com,https://www.writerscreek.com,https://admin.writerscreek.com
CSRF_TRUSTED_ORIGINS=https://writerscreek.com,https://www.writerscreek.com,https://admin.writerscreek.com

# ── Encryption ────────────────────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY=                                # ← CHANGE THIS (Fernet key)
TOKEN_ENCRYPTION_KEY=                                # ← CHANGE THIS (Fernet key)

# ── File storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=do_spaces
USE_S3=True
AWS_ACCESS_KEY_ID=                                   # ← CHANGE THIS
AWS_SECRET_ACCESS_KEY=                               # ← CHANGE THIS
AWS_STORAGE_BUCKET_NAME=                             # ← CHANGE THIS
DO_SPACES_REGION=nyc3
DO_SPACES_CDN_ENDPOINT=                              # ← CHANGE THIS  e.g. your-space.nyc3.cdn.digitaloceanspaces.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=/var/log/writing-system

# ── Optional ─────────────────────────────────────────────────────────────────
GEOLOCATION_API_KEY=
