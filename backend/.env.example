# Django Settings
DJANGO_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
WAGTAILADMIN_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database Configuration
POSTGRES_DB_NAME=writing_system_db
POSTGRES_USER_NAME=postgres
POSTGRES_PASSWORD=your-db-password-here
DB_HOST=db
POSTGRES_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:your-redis-password-here@redis:6379/0
CELERY_BROKER_URL=redis://:your-redis-password-here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your-redis-password-here@redis:6379/0
COMMUNICATIONS_REDIS_URL=redis://:your-redis-password-here@redis:6379/2
CHANNEL_REDIS_URL=redis://:your-redis-password-here@redis:6379/3

# Security
FIELD_ENCRYPTION_KEY=your-fernet-key
TOKEN_ENCRYPTION_KEY=your-token-encryption-key

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
SENDGRID_API_KEY=

# Storage: local, s3, or do_spaces
STORAGE_BACKEND=local
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1
DO_SPACES_REGION=nyc3
DO_SPACES_CDN_ENDPOINT=

# Twilio Configuration (Optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Sentry Configuration (Optional)
SENTRY_DSN=your-sentry-dsn

# Logging
LOG_DIR=/var/log/writing-system
