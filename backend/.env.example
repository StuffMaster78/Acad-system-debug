# ─────────────────────────────────────────────────────────────────────────────
# Django Core
# ─────────────────────────────────────────────────────────────────────────────
DJANGO_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
WAGTAILADMIN_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
TIME_ZONE=UTC
APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB_NAME=writing_system_db
POSTGRES_USER_NAME=postgres
POSTGRES_PASSWORD=your-db-password-here
DB_HOST=db
POSTGRES_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=600
DB_ATOMIC_REQUESTS=False

# ─────────────────────────────────────────────────────────────────────────────
# Redis + Celery
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:your-redis-password-here@redis:6379/0
CELERY_BROKER_URL=redis://:your-redis-password-here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your-redis-password-here@redis:6379/0
COMMUNICATIONS_REDIS_URL=redis://:your-redis-password-here@redis:6379/2
CHANNEL_REDIS_URL=redis://:your-redis-password-here@redis:6379/3
CELERY_TASK_ALWAYS_EAGER=False
CELERY_RESULT_EXPIRES=3600

# ─────────────────────────────────────────────────────────────────────────────
# Security / Encryption
# ─────────────────────────────────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY=your-fernet-key
TOKEN_ENCRYPTION_KEY=your-token-encryption-key

# ─────────────────────────────────────────────────────────────────────────────
# CORS / CSRF
# ─────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Email
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
SENDGRID_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Storage  (STORAGE_BACKEND: local | s3 | do_spaces)
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1
DO_SPACES_REGION=nyc3
DO_SPACES_CDN_ENDPOINT=


# ─────────────────────────────────────────────────────────────────────────────
# CMS Intelligence (Google Search Console + Google Analytics 4)
# ─────────────────────────────────────────────────────────────────────────────
GA4_PROPERTY_ID=
GSC_PROPERTY_URL=https://www.yourdomain.com/
# Full JSON of a Google service account with GSC + GA4 read-only permissions
GOOGLE_SERVICE_ACCOUNT_JSON=
# OpenAI API key for semantic content embeddings (leave blank to skip)
EMBEDDING_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Payments — Stripe
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# Notifications — rate limiting
# ─────────────────────────────────────────────────────────────────────────────
NOTIFICATION_RATE_LIMIT_MAX=10
NOTIFICATION_RATE_LIMIT_WINDOW_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# Files — delivery guard
# ─────────────────────────────────────────────────────────────────────────────
# Signed download URL lifetime in seconds (default 900 = 15 min)
FILE_SIGNED_URL_EXPIRY_SECONDS=900

# ─────────────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
LOG_DIR=/var/log/writing-system
ROOT_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Feature flags  (set to true to enable)
# ─────────────────────────────────────────────────────────────────────────────
FF_DELIVERY_GUARD=true
FF_REFERRAL_INVITATIONS=true
FF_SPECIAL_ORDER_DISCOUNT=true

# ─────────────────────────────────────────────────────────────────────────────
# Remote config (set REMOTE_CONFIG=true to enable DB-driven config at boot)
# ─────────────────────────────────────────────────────────────────────────────
REMOTE_CONFIG=false

# ─────────────────────────────────────────────────────────────────────────────
# Secrets manager (optional — leave empty to use env vars only)
# Set AWS_SECRETS_MANAGER_PREFIX to pull secrets from AWS Secrets Manager.
# e.g. AWS_SECRETS_MANAGER_PREFIX=my-app/production/
# ─────────────────────────────────────────────────────────────────────────────
AWS_SECRETS_MANAGER_PREFIX=
AWS_SECRETS_MANAGER_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# Twilio (optional — SMS notifications)
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
