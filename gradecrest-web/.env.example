# GradeCrest — Nuxt environment variables
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.

# Django backend base URL (no trailing slash)
# Dev:        http://localhost:8000
# Production: https://api.gradecrest.com
NUXT_PUBLIC_API_BASE=http://localhost:8000

# Client portal base URL (no trailing slash)
# Dev:        http://localhost:3001
# Production: https://app.gradecrest.com
NUXT_PUBLIC_APP_URL=http://localhost:3001

# Canonical site URL — used by sitemap and og:url
NUXT_SITE_URL=https://gradecrest.com

# Server-only: direct Django URL for SSR API calls (skips the nginx round-trip)
# Production:  http://web:8000  (Docker internal service name)
# Dev:         leave empty — falls back to NUXT_PUBLIC_API_BASE
NUXT_API_BASE_INTERNAL=
