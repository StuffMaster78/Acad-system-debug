# =============================================================================
# Writers Creek — Frontend production environment
# Vite bakes these values into the compiled bundle at build time.
#
# VITE_API_BASE_URL is intentionally empty — in production, nginx serves the
# frontend and proxies /api/* to Django on the same origin, so no explicit
# base URL is needed. Leaving it empty makes all API calls relative.
# =============================================================================

VITE_API_BASE_URL=
VITE_API_PREFIX=/api/v1
VITE_ORDERS_API_PREFIX=/api/v1/orders
VITE_SSE_URL=/api/v1/notifications/stream/
VITE_APP_NAME=Writers Creek
VITE_SENTRY_DSN=
