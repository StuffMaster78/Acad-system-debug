# =============================================================================
# Writing System Platform — .gitignore
# =============================================================================

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example          # keep example/template files
!.env.*.example
*.env
*.env.local
*.env.backup
*.env.prod
*.env.production
*.env.staging
*.env.test
.envrc                 # direnv

# Docker secrets
docker-secrets/
secrets/
.secrets/

# ── SSL / TLS certificates & keys ─────────────────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.der
*.p12
*.pfx
*.jks
*.keystore
*.truststore
nginx/certs/           # Let's Encrypt certs mounted at runtime

# ── SSH keys ──────────────────────────────────────────────────────────────────
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
*.ppk                  # PuTTY private key

# ── Cloud provider credentials ────────────────────────────────────────────────
# AWS
.aws/
aws-credentials
aws_credentials
credentials.csv

# Google / Firebase
*-service-account.json
*-firebase-adminsdk-*.json
service-account*.json
service_account*.json
google-credentials.json
gcp-credentials.json
*.json.key

# Other providers
.digitalocean/
.linode/

# ── API keys & tokens ─────────────────────────────────────────────────────────
*.token
*.apikey
*.api_key
api_keys.txt
tokens.txt

# ── Database dumps & backups ──────────────────────────────────────────────────
*.sql
*.sql.gz
*.dump
*.pgdump
*.bak
*.backup
backups/

# ── Python ────────────────────────────────────────────────────────────────────
*.pyc
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
dist/
/writerscreek-web/dist
*.egg-info/
*.egg
MANIFEST
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
pip-wheel-metadata/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.tox/
coverage/
.mypy_cache/
.ruff_cache/
nosetests.xml
*.mo
*.pot

# ── Python virtual environments ───────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak
pythonenv*/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/.vitest/
frontend/node_modules/.vite/
gradecrest-web/.nuxt/
**/.output/
.npm
.yarn-integrity
*.tgz
.pnp
.pnp.js

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/
.dist/
staticfiles/
*.min.js.map

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.iml

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore.local    # per-machine overrides

# ── Media / uploads ───────────────────────────────────────────────────────────
backend/media/
media/

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite3
*.db
db.sqlite3

# ── Celery ────────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Sentry & monitoring ───────────────────────────────────────────────────────
.sentryclirc

# ── Terraform / infra state ───────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
.terraform.lock.hcl

# ── Miscellaneous sensitive ───────────────────────────────────────────────────
*.credential
*.credentials
*_credentials*
*_secret*
*-secret*
htpasswd
.htpasswd
passwd
shadow
