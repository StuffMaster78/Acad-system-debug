# Copy to .env and fill in values for your environment.
# Never commit real credentials or production keys.

# ── Development ───────────────────────────────────────────────────────────────
# NUXT_PUBLIC_API_BASE must match the port you start this dev server on.
# The Nuxt nitro devProxy lives on this server and forwards /api/* to Django.
# If running on port 3004: npm run dev -- --port 3004
NUXT_API_BASE_INTERNAL=http://localhost:8000
NUXT_PUBLIC_API_BASE=http://localhost:3004
NUXT_PUBLIC_APP_URL=http://localhost:5173
NUXT_PUBLIC_SITE_URL=http://localhost:3004

# ── Production ────────────────────────────────────────────────────────────────
# NUXT_PUBLIC_API_BASE=https://researchpapermate.com
# NUXT_PUBLIC_APP_URL=https://app.researchpapermate.com
# NUXT_PUBLIC_SITE_URL=https://researchpapermate.com
